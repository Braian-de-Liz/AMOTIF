// Configuração do Gerador e Datasource
generator client {
  provider = "prisma-client-js"
  // binaryTargets = ["native", "debian-openssl-3.0.x"] //APENAS NO DEPLOY
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  nome_completo String
  email         String   @unique
  senha         String
  cpf           String   @unique
  bio           String?
  instrumentos  String[]
  avatar_url    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projetos_criados     Projeto[]     @relation("DonoDoProjeto")
  camadas_enviadas     Camada[]
  projetos_colaborados Colaborador[]

  seguidores    Follows[]      @relation("UserBeingFollowed")
  seguindo      Follows[]      @relation("UserFollowing")
  
  notifications      Notification[] @relation("UserNotifications")
  notificacoes_feitas Notification[] @relation("NotificationActor") 
}

model Follows {
  followerId String @db.Uuid
  follower   User   @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String @db.Uuid
  following   User   @relation("UserBeingFollowed", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Projeto {
  id            String        @id @default(uuid()) @db.Uuid
  titulo        String
  genero        MusicGenre  
  bpm           Int           @default(120)
  escala        String?
  descricao     String?
  audio_guia    String
  userId        String        @db.Uuid
  autor         User          @relation("DonoDoProjeto", fields: [userId], references: [id], onDelete: Cascade)
  camadas       Camada[]
  colaboradores Colaborador[]
  convites      Convite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([genero]) 
}

enum MusicGenre {
  ROCK
  POP
  JAZZ
  BLUES
  FORRO
  METAL
  HIP_HOP
  ELECTRONIC
  CLASSICAL
  LO_FI
  INDIE
  SERTANEJO
  SAMBA
  MPB
  COUNTRY
  FUNK
  SOUNDTRACK
  REGGAE
}

model Convite {
  id                 String   @id @default(uuid()) @db.Uuid
  projetoId          String   @db.Uuid
  projeto            Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  email_destinatario String
  cargo              String   @default("membro")
  mensagem           String?
  token_convite      String   @unique @default(uuid())
  expira_em          DateTime
  createdAt          DateTime @default(now())

  @@index([projetoId])
  @@index([email_destinatario])
}

model Colaborador {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  usuario   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projetoId String   @db.Uuid
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  cargo    String   @default("membro")
  joinedAt DateTime @default(now())

  @@unique([userId, projetoId])
  @@index([projetoId])
}

model Camada {
  id              String  @id @default(uuid()) @db.Uuid
  nome_trilha     String
  audio_url       String
  instrumento_tag String
  delay_offset    Int     @default(0)
  volume_padrao   Float   @default(1.0)
  esta_aprovada   Boolean @default(false)
  projetoId       String  @db.Uuid
  projeto         Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  userId          String  @db.Uuid
  autor           User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([projetoId])
  @@index([userId])
  @@index([createdAt])
}


model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tipo      NotificationType
  mensagem  String           
  lida      Boolean          @default(false)

  userId    String           @db.Uuid
  usuario   User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  actorId   String?          @db.Uuid 
  origem    User?            @relation("NotificationActor", fields: [actorId], references: [id]) // Relação oficial

  projetoId String?          @db.Uuid 
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum NotificationType {
  INVITE_RECEIVED
  INVITE_ACCEPTED
  NEW_LAYER
  LAYER_APPROVED
  PROJECT_REJECT
  NEW_FOLLOWER
  PROJECT_RELEASED
}