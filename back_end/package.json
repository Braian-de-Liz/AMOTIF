{
  "name": "back_end",
  "version": "1.0.0",
  "type": "module",
  "description": "API do AMOTIF. Plataforma de colaboração musical. compatibilidade com Node e Bun",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "tsup src/server.ts --format esm --clean --minify --target esnext --shims",
    "build_exe": "bun build ./src/server.ts --compile --minify --outfile dist/server",
    "build_deploy": "bun build ./src/server.ts --compile --minify --target=bun-linux-x64 --outfile dist/server-linux",
    "bun_build": "bun build ./src/server.ts --minify --target=bun --outfile dist/server.js",
    "start": "node dist/server.js",
    "bun_start": "bun dist/server.js",
    "start_exe": "./dist/server",
    "check": "tsc --noEmit",
    "conectDB": "bunx prisma validate",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:studio": "bunx prisma studio"
  },
  "keywords": [],
  "author": "Braian de Liz da Silva",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@sinclair/typebox": "^0.34.49",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@prisma/config": "^7.3.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.19.11",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
