{
  "name": "back_end",
  "version": "1.0.0",
  "type": "module",
  "description": "API do AMOTIF. Plataforma de colaboração musical. Runtime Bun.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun build ./src/server.ts  --minify --target=bun --outfile dist/server.js",
    "build_exe": "bun build ./src/server.ts --compile --minify --outfile dist/server",
    "build_deploy": "bun build ./src/server.ts --compile --minify --target=bun-linux-x64 --outfile dist/server-linux",
    "start": "bun dist/server.js",
    "start_exe": "./dist/server",
    "check": "tsc --noEmit",
    "clmodules": "rm -rf node_modules",
    "clean": "rm -rf dist",
    "health": "npx autocannon -c 100 -d 10 http://localhost:3333/health",
    "bench": "bun test tests/performance.test.ts",
    "valich": "bun test tests/validation_bench.test.ts",
    "valid": "bun test tests/validation.test.ts",
    "conectDB": "bunx prisma validate",
    "tables": "bun x prisma db push",
    "db:migrate": "bunx prisma migrate dev",
    "db:generate": "bunx prisma generate",
    "db:studio": "bunx prisma studio"
  },
  "keywords": [],
  "author": "Braian de Liz da Silva",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.4.0",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "@prisma/config": "^7.3.0",
    "@types/autocannon": "^7.12.7",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "prisma": "^7.4.0",
    "typescript": "^5.7.3"
  }
}